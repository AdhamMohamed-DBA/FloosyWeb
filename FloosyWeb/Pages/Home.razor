@page "/home"
@using FloosyWeb.Models
@inject FirebaseService Firebase
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject LocalizationService L

<div class="page-section home-page">

    <div class="section-heading">
        <h3 style="margin:0;">@L.T("Welcome"), @Firebase.GetUserName()! 👋</h3>
    </div>

    <div class="card balance-card" style="text-align:center;">
        <p style="color:gray; margin:0; font-size: 14px;">@L.T("TotalBalance")</p>
        <h1 style="color:#00E676; margin:5px; font-size: 40px;">@TotalBalance.ToString("N2")</h1>
    </div>

    <div style="display:flex; gap:10px; margin-bottom:25px;">
        <button class="btn-primary" style="background-color:#2ecc71;" @onclick="() => ShowTransactionModal(true)">+ @L.T("In")</button>
        <button class="btn-primary" style="background-color:#e74c3c;" @onclick="() => ShowTransactionModal(false)">- @L.T("Out")</button>
        <button class="btn-primary" style="background-color:#3498db;" @onclick="ShowTransferModal">@L.T("Transfer")</button>
    </div>

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; width:100%;">
        <h3 style="margin:0;">Credit Cards 💳</h3>
        <button class="btn-trans btn-auto" style="color:#B388FF; font-weight:bold; font-size:16px; padding:5px 10px; margin:0;" @onclick="ShowAddCreditModal">+ @L.T("Add")</button>
    </div>

    <div style="display:flex; flex-direction:column; gap:10px; margin-bottom:20px;">
        @if (!myData.CreditCards.Any())
        {
            <div style="background:#181818; border:1px dashed #444; border-radius:12px; padding:14px; color:#aaa; font-size:12px; text-align:center;">
                No credit cards yet.
            </div>
        }
        else
        {
            @foreach (var cc in myData.CreditCards.OrderBy(x => x.SortOrder))
            {
                var utilization = cc.CreditLimit <= 0 ? 0 : Math.Min(100, (cc.OutstandingBalance / cc.CreditLimit) * 100);
                var dueSoon = GetCreditDueSoonAmount(cc);
                var dueLabel = GetDueLabelForCard(cc);

                <div style="background-color:@cc.ColorHex; padding:16px; border-radius:15px; cursor:pointer; box-shadow:0 4px 6px rgba(0,0,0,0.3);" @onclick="() => OpenCreditOptions(cc)">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
                        <span style="font-weight:bold; font-size:1.1em; color:white; text-shadow:0 1px 2px rgba(0,0,0,0.5);">@cc.Name</span>
                        <span style="font-size:11px; color:#f5f5f5;">Limit: @cc.CreditLimit.ToString("N2")</span>
                    </div>

                    <div style="display:flex; justify-content:space-between; font-size:12px; color:#fff; margin-bottom:4px;">
                        <span>Outstanding: @cc.OutstandingBalance.ToString("N2")</span>
                        <span>Available: @cc.AvailableCredit.ToString("N2")</span>
                    </div>

                    <div style="width:100%; background:rgba(0,0,0,0.25); height:8px; border-radius:6px; overflow:hidden; margin-bottom:8px;">
                        <div style="width:@utilization%; background:#ffcc80; height:100%;"></div>
                    </div>

                    <div style="display:flex; justify-content:space-between; gap:8px; font-size:11px; color:#f4f4f4; flex-wrap:wrap;">
                        <span>Stmt: day @cc.StatementDay</span>
                        <span>Grace: @cc.GraceDays d</span>
                        <span>@dueLabel</span>
                    </div>

                    @if (dueSoon > 0)
                    {
                        <div style="margin-top:8px; font-size:11px; color:#ffe082;">Pay soon (next cycle): @dueSoon.ToString("N2")</div>
                    }
                </div>
            }
        }
    </div>

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; width:100%;">
        <h3 style="margin:0;">@L.T("MyAccounts")</h3>
        <button class="btn-trans btn-auto" style="color:#00E676; font-weight:bold; font-size:16px; padding: 5px 10px; margin:0;" @onclick="ShowAddAccountModal" aria-label="Add a new account">+ @L.T("Add")</button>
    </div>

    <div style="display:flex; flex-direction:column; gap:10px;">
        @foreach (var acc in myData.Accounts.OrderBy(x => x.SortOrder))
        {
            <div style="background-color:@acc.ColorHex; padding:20px; border-radius:15px; display:flex; justify-content:space-between; align-items:center; cursor:pointer; box-shadow: 0 4px 6px rgba(0,0,0,0.3);"
                 @onclick="() => OpenAccountOptions(acc)">
                <span style="font-weight:bold; font-size:1.2em; color:white; text-shadow: 0 1px 2px rgba(0,0,0,0.5);">@acc.Name</span>
                <span style="font-weight:bold; font-size:1.4em; color:white; text-shadow: 0 1px 2px rgba(0,0,0,0.5);">@acc.Balance.ToString("N2")</span>
            </div>
        }
    </div>

    <div style="margin-top:30px; margin-bottom:10px;">
        <h3 style="margin:0;">@L.T("RecentActivity")</h3>
    </div>

    @if (!myData.History.Any())
    {
        <p style="text-align:center; color:gray; font-size:12px;">@L.T("NoRecentTransactions")</p>
    }
    else
    {
        <div style="display:flex; flex-direction:column; gap:10px;">
            @foreach (var t in myData.History.OrderByDescending(x => x.Date).Take(5))
            {
                <div style="background-color:#1f1f1f; padding:15px; border-radius:10px; display:flex; justify-content:space-between; align-items:center; border-left: 4px solid @t.ColorHex;">
                    <div>
                        <div style="color:@t.ColorHex; font-size:10px;">@t.Category</div>
                        <div style="font-weight:bold; color:white;">@t.Desc</div>
                        <div style="color:gray; font-size:10px;">@t.Date.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div style="text-align:right;">
                        <div style="font-weight:bold; font-size:1.1em; color:@t.ColorHex;">@t.AmountDisplay</div>
                        <button class="icon-btn" style="font-size:14px;" @onclick="() => ConfirmDelete(t)" aria-label="Delete transaction" title="Delete transaction">🗑️</button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (isAddAccModalVisible)
{
    <div class="modal-backdrop">
        <div class="modal-content">
            <h3>@L.T("NewAccount") 🏦</h3>
            <input @bind="newAccName" class="input-dark" placeholder="@L.T("AccountName")" />
            <input type="number" @bind="newAccBalance" class="input-dark" placeholder="@L.T("InitialBalance")" />
            <label style="color:gray; font-size:12px;">@L.T("PickColor")</label>
            <input type="color" @bind="newAccColor" style="width:100%; height:40px; border:none; border-radius:8px; cursor:pointer;" />
            <div style="display:flex; gap:10px; margin-top:15px;">
                <button class="btn-primary" @onclick="SaveNewAccount" style="flex:1;">@L.T("Create")</button>
                <button class="btn-trans" @onclick="() => isAddAccModalVisible = false" style="flex:1;">@L.T("Cancel")</button>
            </div>
        </div>
    </div>
}

@if (isAccOptionsVisible)
{
    <div class="modal-backdrop" @onclick="() => isAccOptionsVisible = false">
        <div class="modal-content" @onclick:stopPropagation="true">
            <h3>@(selectedAccount?.Name ?? "Account")</h3>
            <div style="display:flex; gap:10px; margin-bottom:10px;">
                <button class="btn-primary" style="background:#333; flex:1;" @onclick="() => MoveAccount(-1)">⬆️ @L.T("Up")</button>
                <button class="btn-primary" style="background:#333; flex:1;" @onclick="() => MoveAccount(1)">⬇️ @L.T("Down")</button>
            </div>
            <button class="btn-option" @onclick="PrepareEditBalance">💰 @L.T("EditBalance")</button>
            <button class="btn-option" @onclick="PrepareEditName">✏️ @L.T("Rename")</button>
            <div style="padding:15px; border-bottom:1px solid #333;">
                <label style="font-size:12px; color:gray;">@L.T("ChangeColor")</label>
                <input type="color" @bind="selectedAccount!.ColorHex" @oninput="async (e) => { if (selectedAccount != null && e.Value != null) { selectedAccount.ColorHex = (string)e.Value; await Firebase.Save(myData); } }" style="width:100%; height:30px; border:none; cursor:pointer;" />
            </div>
            <button class="btn-option" style="color:#e74c3c;" @onclick="() => isDeleteAccConfirmVisible = true">🗑️ @L.T("DeleteAccount")</button>
            <button class="btn-trans" style="margin-top:10px;" @onclick="() => isAccOptionsVisible = false">@L.T("Close")</button>
        </div>
    </div>
}

@if (isAddCreditModalVisible)
{
    <div class="modal-backdrop">
        <div class="modal-content">
            <h3>New Credit Card 💳</h3>
            <input @bind="newCreditName" class="input-dark" placeholder="Card name" />
            <input type="number" @bind="newCreditLimit" class="input-dark" placeholder="Credit limit" />
            <input type="number" @bind="newCreditOutstanding" class="input-dark" placeholder="Current owed (optional)" />

            <div style="display:flex; gap:8px;">
                <input type="number" min="1" max="28" @bind="newCreditStatementDay" class="input-dark" style="flex:1;" placeholder="Statement day" />
                <input type="number" min="0" max="90" @bind="newCreditGraceDays" class="input-dark" style="flex:1;" placeholder="Grace days" />
            </div>

            <label style="color:gray; font-size:12px;">@L.T("PickColor")</label>
            <input type="color" @bind="newCreditColor" style="width:100%; height:40px; border:none; border-radius:8px; cursor:pointer; margin-bottom:10px;" />

            <div style="display:flex; gap:10px;">
                <button class="btn-primary" style="flex:1;" @onclick="SaveNewCreditCard">@L.T("Create")</button>
                <button class="btn-trans" style="flex:1;" @onclick="() => isAddCreditModalVisible = false">@L.T("Cancel")</button>
            </div>
        </div>
    </div>
}

@if (isCreditOptionsVisible)
{
    <div class="modal-backdrop" @onclick="() => isCreditOptionsVisible = false">
        <div class="modal-content" @onclick:stopPropagation="true">
            <h3>@(selectedCreditCard?.Name ?? "Credit")</h3>

            <button class="btn-option" @onclick="() => ShowCreditTransactionModal(false)">🛒 Credit Out (use card)</button>
            <button class="btn-option" @onclick="() => ShowCreditTransactionModal(true)">💸 Credit In (pay card)</button>
            <button class="btn-option" @onclick="ShowCreditTransferModal">🔁 Transfer account ↔ credit</button>
            <button class="btn-option" @onclick="PrepareEditCredit">✏️ Edit limit / owed / cycle</button>

            <div style="padding:15px; border-bottom:1px solid #333;">
                <label style="font-size:12px; color:gray;">@L.T("ChangeColor")</label>
                <input type="color" @bind="selectedCreditCard!.ColorHex" @oninput="async (e) => { if (selectedCreditCard != null && e.Value != null) { selectedCreditCard.ColorHex = (string)e.Value; await Firebase.Save(myData); } }" style="width:100%; height:30px; border:none; cursor:pointer;" />
            </div>

            <button class="btn-option" style="color:#e74c3c;" @onclick="() => isDeleteCreditConfirmVisible = true">🗑️ Delete credit card</button>
            <button class="btn-trans" style="margin-top:10px;" @onclick="() => isCreditOptionsVisible = false">@L.T("Close")</button>
        </div>
    </div>
}

@if (isEditCreditModalVisible)
{
    <div class="modal-backdrop">
        <div class="modal-content">
            <h3>Edit Credit Card</h3>
            <input @bind="editCreditName" class="input-dark" placeholder="Card name" />
            <input type="number" @bind="editCreditLimit" class="input-dark" placeholder="Credit limit" />
            <input type="number" @bind="editCreditOutstanding" class="input-dark" placeholder="Outstanding" />
            <div style="display:flex; gap:8px;">
                <input type="number" min="1" max="28" @bind="editCreditStatementDay" class="input-dark" style="flex:1;" placeholder="Statement day" />
                <input type="number" min="0" max="90" @bind="editCreditGraceDays" class="input-dark" style="flex:1;" placeholder="Grace days" />
            </div>
            <div style="display:flex; gap:10px;">
                <button class="btn-primary" style="flex:1;" @onclick="SaveCreditEdits">@L.T("Save")</button>
                <button class="btn-trans" style="flex:1;" @onclick="() => isEditCreditModalVisible = false">@L.T("Cancel")</button>
            </div>
        </div>
    </div>
}

@if (isDeleteCreditConfirmVisible)
{
    <div class="modal-backdrop">
        <div class="modal-content" style="border:1px solid #e74c3c;">
            <h3 style="color:#e74c3c;">Delete credit card?</h3>
            <p style="color:#ccc;">Are you sure to delete <b>@selectedCreditCard?.Name</b>?</p>
            <div style="display:flex; gap:10px;">
                <button class="btn-primary" style="background:#e74c3c; flex:1;" @onclick="ExecuteDeleteCredit">@L.T("YesDelete")</button>
                <button class="btn-trans" style="flex:1;" @onclick="() => isDeleteCreditConfirmVisible = false">@L.T("Cancel")</button>
            </div>
        </div>
    </div>
}

@if (isCreditTransModalVisible)
{
    <div class="modal-backdrop">
        <div class="modal-content">
            <h3 style="margin-top:0;">@(isCreditPayment ? "Credit Payment (In)" : "Credit Expense (Out)")</h3>
            <label style="color:gray; font-size:12px;">@L.T("Date")</label>
            <input type="date" @bind="creditTransDate" class="input-dark" />

            <select @bind="selectedCreditCardId" class="input-dark">
                @foreach (var c in myData.CreditCards.OrderBy(x => x.SortOrder))
                {
                    <option value="@c.Id">@c.Name</option>
                }
            </select>

            <input type="number" @bind="creditTransAmount" class="input-dark" placeholder="@L.T("Amount")" />
            <input @bind="creditTransDesc" class="input-dark" placeholder="@L.T("DescriptionOptional")" />

            @if (!isCreditPayment)
            {
                <div style="background:#2a2a2a; border:1px solid #3a3a3a; border-radius:10px; padding:10px; margin-bottom:10px;">
                    <label style="display:flex; align-items:center; gap:8px; color:#ddd; font-size:13px; margin-bottom:8px;">
                        <input type="checkbox" @bind="convertCreditOutToInstallment" style="accent-color:#00E676;" />
                        Convert this credit-out to installments
                    </label>

                    @if (convertCreditOutToInstallment)
                    {
                        <div style="display:flex; gap:8px;">
                            <input type="number" min="1" max="120" @bind="installmentMonths" class="input-dark" style="flex:1; margin-bottom:0;" placeholder="Months" />
                            <input type="date" @bind="installmentFirstDueDate" class="input-dark" style="flex:1; margin-bottom:0;" />
                        </div>
                        <div style="font-size:11px; color:#aaa; margin-top:6px;">
                            Monthly preview: @GetInstallmentPreviewAmount().ToString("N2")
                        </div>
                        <label style="display:flex; align-items:center; gap:8px; color:#ddd; font-size:12px; margin-top:8px;">
                            <input type="checkbox" @bind="createInstallmentBillNow" style="accent-color:#00E676;" />
                            Create one installment bill now (manual)
                        </label>
                    }
                </div>
            }

            <div style="display:flex; gap:10px;">
                <button class="btn-primary" style="flex:1;" @onclick="SaveCreditTransaction">@L.T("Save")</button>
                <button class="btn-trans" style="flex:1;" @onclick="() => isCreditTransModalVisible = false">@L.T("Cancel")</button>
            </div>
        </div>
    </div>
}

@if (isCreditTransferModalVisible)
{
    <div class="modal-backdrop">
        <div class="modal-content">
            <h3>Transfer Account ↔ Credit</h3>

            <label style="color:gray; font-size:12px;">@L.T("Date")</label>
            <input type="date" @bind="creditTransferDate" class="input-dark" />

            <select @bind="creditTransferDirection" class="input-dark">
                <option value="AccountToCredit">Account → Credit (Pay card)</option>
                <option value="CreditToAccount">Credit → Account (Cash advance)</option>
            </select>

            @if (creditTransferDirection == "CreditToAccount")
            {
                <div style="background:#2a2a2a; border:1px solid #3a3a3a; border-radius:10px; padding:10px; margin-bottom:10px;">
                    <label style="display:flex; align-items:center; gap:8px; color:#ddd; font-size:13px; margin-bottom:8px;">
                        <input type="checkbox" @bind="convertCashoutToInstallment" style="accent-color:#00E676;" />
                        Convert this cash-out to installments
                    </label>

                    @if (convertCashoutToInstallment)
                    {
                        <div style="display:flex; gap:8px;">
                            <input type="number" min="1" max="120" @bind="installmentMonths" class="input-dark" style="flex:1; margin-bottom:0;" placeholder="Months" />
                            <input type="date" @bind="installmentFirstDueDate" class="input-dark" style="flex:1; margin-bottom:0;" />
                        </div>
                        <div style="font-size:11px; color:#aaa; margin-top:6px;">
                            Monthly preview: @GetInstallmentPreviewAmount().ToString("N2")
                        </div>
                        <label style="display:flex; align-items:center; gap:8px; color:#ddd; font-size:12px; margin-top:8px;">
                            <input type="checkbox" @bind="createInstallmentBillNow" style="accent-color:#00E676;" />
                            Create one installment bill now (manual)
                        </label>
                    }
                </div>
            }

            <select @bind="creditTransferAccountId" class="input-dark">
                @foreach (var a in myData.Accounts)
                {
                    <option value="@a.Id">Account: @a.Name</option>
                }
            </select>

            <select @bind="creditTransferCardId" class="input-dark">
                @foreach (var c in myData.CreditCards.OrderBy(x => x.SortOrder))
                {
                    <option value="@c.Id">Credit: @c.Name</option>
                }
            </select>

            <input type="number" @bind="creditTransferAmount" class="input-dark" placeholder="@L.T("Amount")" />
            <input @bind="creditTransferDesc" class="input-dark" placeholder="@L.T("DescriptionOptional")" />

            <div style="display:flex; gap:10px;">
                <button class="btn-primary" style="flex:1;" @onclick="SaveCreditTransfer">@L.T("Confirm")</button>
                <button class="btn-trans" style="flex:1;" @onclick="() => isCreditTransferModalVisible = false">@L.T("Cancel")</button>
            </div>
        </div>
    </div>
}

@if (isRenameModalVisible)
{
    <div class="modal-backdrop">
        <div class="modal-content">
            <h3>@L.T("RenameAccount")</h3>
            <input @bind="editNameValue" class="input-dark" placeholder="@L.T("NewName")" />
            <div style="display:flex; gap:10px;">
                <button class="btn-primary" style="flex:1;" @onclick="SaveAccountName">@L.T("Save")</button>
                <button class="btn-trans" style="flex:1;" @onclick="() => isRenameModalVisible = false">@L.T("Cancel")</button>
            </div>
        </div>
    </div>
}

@if (isBalanceModalVisible)
{
    <div class="modal-backdrop">
        <div class="modal-content">
            <h3>@L.T("EditBalance")</h3>
            <input type="number" @bind="editBalanceValue" class="input-dark" />
            <div style="display:flex; gap:10px;">
                <button class="btn-primary" style="flex:1;" @onclick="SaveAccountBalance">@L.T("Save")</button>
                <button class="btn-trans" style="flex:1;" @onclick="() => isBalanceModalVisible = false">@L.T("Cancel")</button>
            </div>
        </div>
    </div>
}

@if (isDeleteAccConfirmVisible)
{
    <div class="modal-backdrop">
        <div class="modal-content" style="border:1px solid #e74c3c;">
            <h3 style="color:#e74c3c;">@L.T("DeleteAccountQuestion")</h3>
            <p style="color:#ccc;">@L.T("DeleteAccountConfirm") <b>@selectedAccount?.Name</b>?</p>
            <div style="display:flex; gap:10px;">
                <button class="btn-primary" style="background:#e74c3c; flex:1;" @onclick="ExecuteDeleteAccount">@L.T("YesDelete")</button>
                <button class="btn-trans" style="flex:1;" @onclick="() => isDeleteAccConfirmVisible = false">@L.T("Cancel")</button>
            </div>
        </div>
    </div>
}

@if (isTransModalVisible)
{
    <div class="modal-backdrop">
        <div class="modal-content">
            <h3 style="margin-top:0;">@(isIncome ? L.T("NewIncome") : L.T("NewExpense"))</h3>
            <label style="color:gray; font-size:12px;">@L.T("Date")</label>
            <input type="date" @bind="transDate" class="input-dark" />
            <select @bind="selectedAccountId" class="input-dark">
                @foreach (var a in myData.Accounts)
                {
                    <option value="@a.Id">@a.Name</option>
                }
            </select>
            <input type="number" @bind="transAmount" class="input-dark" placeholder="@L.T("Amount")" />
            <div style="display:flex; gap:5px;">
                <select @bind="selectedCategory" class="input-dark" style="flex:1;">
                    @foreach (var c in (isIncome ? myData.IncomeCategories : myData.ExpenseCategories))
                    {
                        <option value="@c">@c</option>
                    }
                </select>
                <button class="icon-btn" style="background:#333; border:none; color:white; border-radius:8px; width:40px; margin-bottom:10px;" @onclick="() => isManageCatsVisible = true" aria-label="Manage categories" title="Manage categories">⚙️</button>
            </div>
            <input @bind="transDesc" class="input-dark" placeholder="@L.T("DescriptionOptional")" />
            <div style="display:flex; gap:10px;">
                <button class="btn-primary" @onclick="SaveTransaction" style="flex:1;">@L.T("Save")</button>
                <button class="btn-trans" @onclick="() => isTransModalVisible = false" style="flex:1;">@L.T("Cancel")</button>
            </div>
        </div>
    </div>
}

@if (isManageCatsVisible)
{
    <div class="modal-backdrop" style="z-index:2100;">
        <div class="modal-content">
            <h3>@L.T("ManageCategories")</h3>
            <div style="display:flex; gap:5px; margin-bottom:15px;">
                <input @bind="newCatName" class="input-dark" placeholder="@L.T("NewCategory")" style="margin-bottom:0;" />
                <button class="btn-primary btn-auto" style="width:auto;" @onclick="AddCategory">+</button>
            </div>
            <div style="max-height:200px; overflow-y:auto;">
                @foreach (var c in (isIncome ? myData.IncomeCategories : myData.ExpenseCategories).ToList())
                {
                    <div style="display:flex; justify-content:space-between; padding:10px; border-bottom:1px solid #333; color:white;">
                        <span>@c</span>
                        <button class="btn-auto" style="color:#e74c3c; background:none; border:none; width:auto;" @onclick="() => DeleteCategory(c)" aria-label="Delete category" title="Delete category">✕</button>
                    </div>
                }
            </div>
            <button class="btn-trans" style="margin-top:10px;" @onclick="() => isManageCatsVisible = false">@L.T("Close")</button>
        </div>
    </div>
}

@if (isDeleteModalVisible)
{
    <div class="modal-backdrop">
        <div class="modal-content">
            <h3>@L.T("DeleteTransactionQuestion")</h3>
            <p style="color:gray;">@selectedTrans.Desc (@selectedTrans.AmountDisplay)</p>
            <select @bind="refundAccountId" class="input-dark">
                <option value="">@L.T("DontChangeBalance")</option>
                @foreach (var acc in myData.Accounts)
                {
                    <option value="@acc.Id">@(isIncomeTrans ? L.T("DeductFrom") : L.T("RefundTo")) @acc.Name</option>
                }
                @foreach (var cc in myData.CreditCards.OrderBy(x => x.SortOrder))
                {
                    <option value="cc:@cc.Id">@(isIncomeTrans ? L.T("DeductFrom") : L.T("RefundTo")) Credit • @cc.Name</option>
                }
            </select>
            <div style="display:flex; gap:10px;">
                <button class="btn-primary" style="background:#e74c3c; flex:1;" @onclick="ExecuteDelete">@L.T("Delete")</button>
                <button class="btn-trans" style="flex:1;" @onclick="() => isDeleteModalVisible = false">@L.T("Cancel")</button>
            </div>
        </div>
    </div>
}

@if (isTransferModalVisible)
{
    <div class="modal-backdrop">
        <div class="modal-content">
            <h3>@L.T("Transfer")</h3>
            <label style="color:gray; font-size:12px;">@L.T("Date")</label>
            <input type="date" @bind="transDate" class="input-dark" />
            <select @bind="transferFromId" class="input-dark">
                @foreach (var a in myData.Accounts)
                {
                    <option value="@a.Id">@L.T("From") @a.Name</option>
