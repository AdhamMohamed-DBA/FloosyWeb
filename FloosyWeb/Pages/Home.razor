@code {
    AppData myData = new AppData();
    decimal TotalBalance => myData.Accounts.Sum(x => x.Balance);

    // UI Flags
    bool isAddAccModalVisible = false;
    bool isAccOptionsVisible = false;
    bool isRenameModalVisible = false; // 🔥 New
    bool isBalanceModalVisible = false; // 🔥 New
    bool isDeleteAccConfirmVisible = false; // 🔥 New
    bool isTransModalVisible = false;
    bool isManageCatsVisible = false;
    bool isDeleteModalVisible = false;
    bool isTransferModalVisible = false;
    bool isIncome = true;

    bool isAddCreditModalVisible = false;
    bool isCreditOptionsVisible = false;
    bool isEditCreditModalVisible = false;
    bool isDeleteCreditConfirmVisible = false;
    bool isCreditTransModalVisible = false;
    bool isCreditTransferModalVisible = false;
    bool isCreditPayment = false;

    // Data Vars
    string newAccName = "", newAccColor = "#00E676";
    decimal newAccBalance;
    string newCatName = "";
    Account? selectedAccount;
    string selectedAccountId = "", selectedCategory = "", transDesc = "";
    decimal transAmount;
    string transferFromId = "", transferToId = "";
    decimal transferAmount;

    CreditCard? selectedCreditCard;
    string selectedCreditCardId = "";
    string newCreditName = "";
    decimal newCreditLimit = 0;
    decimal newCreditOutstanding = 0;
    int newCreditStatementDay = 25;
    int newCreditGraceDays = 25;
    string newCreditColor = "#7E57C2";

    string editCreditName = "";
    decimal editCreditLimit = 0;
    decimal editCreditOutstanding = 0;
    int editCreditStatementDay = 25;
    int editCreditGraceDays = 25;

    decimal creditTransAmount = 0;
    string creditTransDesc = "";
    DateTime creditTransDate = DateTime.Now;

    string creditTransferDirection = "AccountToCredit";
    string creditTransferAccountId = "";
    string creditTransferCardId = "";
    decimal creditTransferAmount = 0;
    string creditTransferDesc = "";
    DateTime creditTransferDate = DateTime.Now;
    bool convertCashoutToInstallment = false;
    bool convertCreditOutToInstallment = false;
    bool createInstallmentBillNow = false;
    int installmentMonths = 12;
    DateTime installmentFirstDueDate = DateTime.Now.AddMonths(1);
    Transaction selectedTrans = new Transaction();
    string refundAccountId = "";
    bool isIncomeTrans = false;
    DateTime transDate = DateTime.Now;

    // Temp vars for Editing
    string editNameValue = "";
    decimal editBalanceValue = 0;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Firebase.CurrentUserId)) { Nav.NavigateTo("/"); return; }
        myData = await Firebase.Load();
        myData.CreditCards ??= [];
        if (!myData.Accounts.Any()) { await Task.Delay(500); myData = await Firebase.Load(); }
        if (myData.Accounts.Any()) selectedAccountId = myData.Accounts.First().Id;
        if (myData.CreditCards.Any()) selectedCreditCardId = myData.CreditCards.OrderBy(x => x.SortOrder).First().Id;

        if (myData.Accounts.Any(x => x.SortOrder == 0))
        {
            for (int i = 0; i < myData.Accounts.Count; i++) myData.Accounts[i].SortOrder = i;
        }
        InitCats();

        if (myData.CreditCards.Any(x => x.SortOrder == 0))
        {
            for (int i = 0; i < myData.CreditCards.Count; i++) myData.CreditCards[i].SortOrder = i;
        }
    }

    decimal GetCreditDueSoonAmount(CreditCard cc)
    {
        var nextDue = GetNextDueDateForCard(cc);
        if (!nextDue.HasValue) return 0;

        var targetDue = nextDue.Value.Date;
        return GetCreditDueEligibleTransactions(cc)
            .Where(x => x.CreditDueDate!.Value.Date == targetDue)
            .Sum(x => x.Amount);
    }

    DateTime? GetNextDueDateForCard(CreditCard cc)
    {
        var dueDates = GetCreditDueEligibleTransactions(cc)
            .Select(x => x.CreditDueDate!.Value.Date)
            .Distinct()
            .OrderBy(d => d)
            .ToList();

        if (!dueDates.Any()) return null;
        return dueDates[0];
    }

    string GetDueLabelForCard(CreditCard cc)
    {
        var dueDate = GetNextDueDateForCard(cc);
        if (!dueDate.HasValue) return "Next Due: -";

        var today = DateTime.Now.Date;
        if (dueDate.Value.Date == today)
            return $"Due Today: {dueDate.Value:dd MMM}";

        return $"Next Due: {dueDate.Value:dd MMM}";
    }

    IEnumerable<Transaction> GetCreditDueEligibleTransactions(CreditCard cc)
    {
        var today = DateTime.Now.Date;
        return myData.History
            .Where(x => x.PrimaryCreditCardId == cc.Id
                && x.CreditDueDate.HasValue
                && x.CreditDueDate.Value.Date >= today
                && !x.IsInstallmentRelated
                && IsCreditChargeKind(x.Kind));
    }

    static bool IsCreditChargeKind(string? kind)
    {
        return string.Equals(kind, "CreditExpense", StringComparison.OrdinalIgnoreCase)
            || string.Equals(kind, "CreditTransferOut", StringComparison.OrdinalIgnoreCase)
            || string.Equals(kind, "BillPaidByCredit", StringComparison.OrdinalIgnoreCase);
    }

    decimal GetInstallmentPreviewAmount()
    {
        var sourceAmount = isCreditTransferModalVisible ? creditTransferAmount : creditTransAmount;
        if (sourceAmount <= 0) return 0;
        var months = Math.Clamp(installmentMonths, 1, 120);
        return Math.Round(sourceAmount / months, 2);
    }

    void ShowAddCreditModal()
    {
        newCreditName = "";
        newCreditLimit = 0;
        newCreditOutstanding = 0;
        newCreditStatementDay = 25;
        newCreditGraceDays = 25;
        newCreditColor = "#7E57C2";
        isAddCreditModalVisible = true;
    }

    async Task SaveNewCreditCard()
    {
        if (string.IsNullOrWhiteSpace(newCreditName)) return;

        var nextOrder = myData.CreditCards.Any() ? myData.CreditCards.Max(x => x.SortOrder) + 1 : 0;
        var card = new CreditCard
        {
            Name = newCreditName.Trim(),
            CreditLimit = Math.Max(0, newCreditLimit),
            OutstandingBalance = Math.Max(0, newCreditOutstanding),
            StatementDay = CreditCycleHelper.NormalizeDay(newCreditStatementDay),
            GraceDays = CreditCycleHelper.NormalizeGraceDays(newCreditGraceDays),
            ColorHex = newCreditColor,
            SortOrder = nextOrder
        };

        myData.CreditCards.Add(card);
        selectedCreditCardId = card.Id;

        if (card.OutstandingBalance > 0)
        {
            myData.History.Add(new Transaction
            {
                Kind = "CreditAdjustment",
                Desc = $"Initial outstanding for {card.Name}",
                Category = "Credit",
                Amount = card.OutstandingBalance,
                AmountDisplay = $"-{card.OutstandingBalance:N2}",
                ColorHex = "#9b59b6",
                PrimaryCreditCardId = card.Id,
                PrimaryCreditCardName = card.Name,
                CreditStatementDate = CreditCycleHelper.GetStatementDateForTransaction(DateTime.Now, card.StatementDay),
                CreditDueDate = CreditCycleHelper.GetDueDateForTransaction(DateTime.Now, card.StatementDay, card.GraceDays),
                Date = DateTime.Now
            });
        }

        await Firebase.Save(myData);
        isAddCreditModalVisible = false;
    }

    void OpenCreditOptions(CreditCard card)
    {
        selectedCreditCard = card;
        selectedCreditCardId = card.Id;
        isCreditOptionsVisible = true;
    }

    void PrepareEditCredit()
    {
        if (selectedCreditCard == null) return;
        editCreditName = selectedCreditCard.Name;
        editCreditLimit = selectedCreditCard.CreditLimit;
        editCreditOutstanding = selectedCreditCard.OutstandingBalance;
        editCreditStatementDay = selectedCreditCard.StatementDay;
        editCreditGraceDays = selectedCreditCard.GraceDays;
        isEditCreditModalVisible = true;
    }

    async Task SaveCreditEdits()
    {
        if (selectedCreditCard == null) return;

        var oldOutstanding = selectedCreditCard.OutstandingBalance;

        selectedCreditCard.Name = string.IsNullOrWhiteSpace(editCreditName) ? selectedCreditCard.Name : editCreditName.Trim();
        selectedCreditCard.CreditLimit = Math.Max(0, editCreditLimit);
        selectedCreditCard.OutstandingBalance = Math.Max(0, editCreditOutstanding);
        selectedCreditCard.StatementDay = CreditCycleHelper.NormalizeDay(editCreditStatementDay);
        selectedCreditCard.GraceDays = CreditCycleHelper.NormalizeGraceDays(editCreditGraceDays);

        var delta = selectedCreditCard.OutstandingBalance - oldOutstanding;
        if (delta != 0)
        {
            var isIncrease = delta > 0;
            var abs = Math.Abs(delta);
            myData.History.Add(new Transaction
            {
                Kind = "CreditAdjustment",
                Desc = $"Manual adjustment: {selectedCreditCard.Name}",
                Category = "Credit",
                Amount = abs,
                AmountDisplay = isIncrease ? $"-{abs:N2}" : $"+{abs:N2}",
                ColorHex = "#9b59b6",
                PrimaryCreditCardId = selectedCreditCard.Id,
                PrimaryCreditCardName = selectedCreditCard.Name,
                CreditStatementDate = CreditCycleHelper.GetStatementDateForTransaction(DateTime.Now, selectedCreditCard.StatementDay),
                CreditDueDate = CreditCycleHelper.GetDueDateForTransaction(DateTime.Now, selectedCreditCard.StatementDay, selectedCreditCard.GraceDays),
                Date = DateTime.Now
            });
        }

        await Firebase.Save(myData);
        isEditCreditModalVisible = false;
    }

    async Task ExecuteDeleteCredit()
    {
        if (selectedCreditCard == null) return;

        myData.CreditCards.Remove(selectedCreditCard);
        await Firebase.Save(myData);
        isDeleteCreditConfirmVisible = false;
        isCreditOptionsVisible = false;
    }

    void ShowCreditTransactionModal(bool isPayment)
    {
        isCreditPayment = isPayment;
        creditTransAmount = 0;
        creditTransDesc = "";
        creditTransDate = DateTime.Now;
        convertCreditOutToInstallment = false;
        createInstallmentBillNow = false;
        installmentMonths = 12;
        installmentFirstDueDate = DateTime.Now.AddMonths(1);
        if (selectedCreditCard != null) selectedCreditCardId = selectedCreditCard.Id;
        isCreditTransModalVisible = true;
    }

    async Task SaveCreditTransaction()
    {
        if (creditTransAmount <= 0) return;

        var card = myData.CreditCards.FirstOrDefault(x => x.Id == selectedCreditCardId);
        if (card == null) return;

        var isInstallmentCreditOut = !isCreditPayment && convertCreditOutToInstallment;
        var installmentPlanId = isInstallmentCreditOut ? Guid.NewGuid().ToString() : null;
        var installmentTotalCount = isInstallmentCreditOut ? Math.Clamp(installmentMonths, 1, 120) : (int?)null;

        if (isCreditPayment)
        {
            card.OutstandingBalance -= creditTransAmount;
            if (card.OutstandingBalance < 0) card.OutstandingBalance = 0;
        }
        else
        {
            card.OutstandingBalance += creditTransAmount;
        }

        var statementDate = CreditCycleHelper.GetStatementDateForTransaction(creditTransDate, card.StatementDay);
        var dueDate = CreditCycleHelper.GetDueDateForTransaction(creditTransDate, card.StatementDay, card.GraceDays);

        var tx = new Transaction
        {
            Kind = isCreditPayment ? "CreditPayment" : "CreditExpense",
            Desc = string.IsNullOrWhiteSpace(creditTransDesc)
                ? (isCreditPayment ? $"Credit payment: {card.Name}" : $"Credit expense: {card.Name}")
                : creditTransDesc,
            Category = "Credit",
            Amount = creditTransAmount,
            AmountDisplay = isCreditPayment ? $"+{creditTransAmount:N2}" : $"-{creditTransAmount:N2}",
            ColorHex = isCreditPayment ? "#2ecc71" : "#e74c3c",
            PrimaryCreditCardId = card.Id,
            PrimaryCreditCardName = card.Name,
            CreditStatementDate = statementDate,
            CreditDueDate = isInstallmentCreditOut ? null : dueDate,
            IsCreditGraceEligible = !isCreditPayment,
            IsInstallmentRelated = isInstallmentCreditOut,
            InstallmentPlanId = installmentPlanId,
            InstallmentNumber = isInstallmentCreditOut ? 0 : null,
            InstallmentTotalCount = installmentTotalCount,
            Date = creditTransDate
        };

        myData.History.Add(tx);

        if (isInstallmentCreditOut && createInstallmentBillNow)
        {
            CreateSingleInstallmentBill(
                card,
                creditTransAmount,
                installmentTotalCount ?? 1,
                installmentFirstDueDate,
                installmentPlanId ?? Guid.NewGuid().ToString(),
                tx.Id,
                string.IsNullOrWhiteSpace(creditTransDesc) ? $"Installment {card.Name}" : creditTransDesc.Trim());
        }

        await Firebase.Save(myData);
        isCreditTransModalVisible = false;
    }

    void ShowCreditTransferModal()
    {
        if (!myData.Accounts.Any() || !myData.CreditCards.Any()) return;
        creditTransferDirection = "AccountToCredit";
        creditTransferAccountId = myData.Accounts.First().Id;
        creditTransferCardId = selectedCreditCard?.Id ?? myData.CreditCards.OrderBy(x => x.SortOrder).First().Id;
        creditTransferAmount = 0;
        creditTransferDesc = "";
        creditTransferDate = DateTime.Now;
        convertCashoutToInstallment = false;
        createInstallmentBillNow = false;
        installmentMonths = 12;
        installmentFirstDueDate = DateTime.Now.AddMonths(1);
        isCreditTransferModalVisible = true;
    }

    void CreateSingleInstallmentBill(
        CreditCard card,
        decimal totalAmount,
        int months,
        DateTime firstDueDate,
        string planId,
        string? linkedTransactionId,
        string? notePrefix)
    {
        var safeMonths = Math.Clamp(months, 1, 120);
        var normalizedFirstDue = firstDueDate.Date;
        var amount = safeMonths == 1
            ? totalAmount
            : Math.Round(totalAmount / safeMonths, 2);

        myData.Bills.Add(new Bill
        {
            Name = string.IsNullOrWhiteSpace(notePrefix)
                ? $"Installment 1/{safeMonths} • {card.Name}"
                : $"{notePrefix} • 1/{safeMonths}",
            Amount = amount,
            DueDate = normalizedFirstDue,
            Frequency = "OneTime",
            Category = "Installment",
            Notes = $"Manually created installment bill for {card.Name}",
            IsInstallment = true,
            InstallmentPlanId = planId,
            InstallmentNumber = 1,
            InstallmentTotalCount = safeMonths,
            LinkedCreditCardId = card.Id,
            LinkedCreditCardName = card.Name,
            LinkedTransactionId = linkedTransactionId
        });
    }

    async Task SaveCreditTransfer()
    {
        if (creditTransferAmount <= 0) return;

        var acc = myData.Accounts.FirstOrDefault(x => x.Id == creditTransferAccountId);
        var card = myData.CreditCards.FirstOrDefault(x => x.Id == creditTransferCardId);
        if (acc == null || card == null) return;

        if (creditTransferDirection == "AccountToCredit")
        {
            if (acc.Balance < creditTransferAmount) return;

            acc.Balance -= creditTransferAmount;
            card.OutstandingBalance -= creditTransferAmount;
            if (card.OutstandingBalance < 0) card.OutstandingBalance = 0;

            myData.History.Add(new Transaction
            {
                Kind = "CreditTransferIn",
                Desc = string.IsNullOrWhiteSpace(creditTransferDesc)
                    ? $"Pay {card.Name} from {acc.Name}"
                    : creditTransferDesc,
                Category = "CreditTransfer",
                Amount = creditTransferAmount,
                AmountDisplay = $"{creditTransferAmount:N2}",
                ColorHex = "#3498db",
                PrimaryAccountId = acc.Id,
                PrimaryAccountName = acc.Name,
                TargetCreditCardId = card.Id,
                TargetCreditCardName = card.Name,
                CreditStatementDate = CreditCycleHelper.GetStatementDateForTransaction(creditTransferDate, card.StatementDay),
                CreditDueDate = null,
                IsCreditGraceEligible = false,
                Date = creditTransferDate
            });
        }
        else
        {
            if (card.AvailableCredit < creditTransferAmount) return;

            acc.Balance += creditTransferAmount;
            card.OutstandingBalance += creditTransferAmount;

            var planId = convertCashoutToInstallment ? Guid.NewGuid().ToString() : null;
            var transferTx = new Transaction
            {
                Kind = "CreditTransferOut",
                Desc = string.IsNullOrWhiteSpace(creditTransferDesc)
                    ? $"Cash advance {card.Name} to {acc.Name}"
                    : creditTransferDesc,
                Category = "CreditTransfer",
                Amount = creditTransferAmount,
                AmountDisplay = $"{creditTransferAmount:N2}",
                ColorHex = "#8e44ad",
                PrimaryCreditCardId = card.Id,
                PrimaryCreditCardName = card.Name,
                TargetAccountId = acc.Id,
                TargetAccountName = acc.Name,
                CreditStatementDate = CreditCycleHelper.GetStatementDateForTransaction(creditTransferDate, card.StatementDay),
                CreditDueDate = convertCashoutToInstallment ? null : CreditCycleHelper.GetCashAdvanceDueDateForTransaction(creditTransferDate, card.StatementDay),
                IsCreditGraceEligible = false,
                IsInstallmentRelated = convertCashoutToInstallment,
                InstallmentPlanId = planId,
                InstallmentNumber = convertCashoutToInstallment ? 0 : null,
                InstallmentTotalCount = convertCashoutToInstallment ? Math.Clamp(installmentMonths, 1, 120) : null,
                Date = creditTransferDate
            };

            myData.History.Add(transferTx);

            if (convertCashoutToInstallment && createInstallmentBillNow)
            {
                CreateSingleInstallmentBill(
                    card,
                    creditTransferAmount,
                    installmentMonths,
                    installmentFirstDueDate,
                    planId ?? Guid.NewGuid().ToString(),
                    transferTx.Id,
                    string.IsNullOrWhiteSpace(creditTransferDesc) ? $"Installment {card.Name}" : creditTransferDesc.Trim());
            }
        }

        await Firebase.Save(myData);
        isCreditTransferModalVisible = false;
    }

    void InitCats()
    {
        if (!myData.IncomeCategories.Any()) myData.IncomeCategories = new System.Collections.ObjectModel.ObservableCollection<string> { L.IsArabic ? "راتب" : "Salary", L.IsArabic ? "مكافأة" : "Bonus" };
        if (!myData.ExpenseCategories.Any()) myData.ExpenseCategories = new System.Collections.ObjectModel.ObservableCollection<string> { L.IsArabic ? "طعام" : "Food", L.IsArabic ? "مواصلات" : "Transport" };
    }

    void ShowAddAccountModal() { newAccName = ""; newAccBalance = 0; newAccColor = "#00E676"; isAddAccModalVisible = true; }

    async Task SaveNewAccount()
    {
        if (string.IsNullOrWhiteSpace(newAccName)) return;
        var nextOrder = myData.Accounts.Any() ? myData.Accounts.Max(x => x.SortOrder) + 1 : 0;
        myData.Accounts.Add(new Account { Name = newAccName, Balance = newAccBalance, ColorHex = newAccColor, SortOrder = nextOrder });
        await Firebase.Save(myData); isAddAccModalVisible = false;
    }

    void OpenAccountOptions(Account acc) { selectedAccount = acc; isAccOptionsVisible = true; }

    async Task MoveAccount(int direction)
    {
        if (selectedAccount == null) return;
        var list = myData.Accounts.OrderBy(x => x.SortOrder).ToList();
        int index = list.IndexOf(selectedAccount);
        if (direction == -1 && index > 0)
        {
            var other = list[index - 1];
            int temp = selectedAccount.SortOrder;
            selectedAccount.SortOrder = other.SortOrder;
            other.SortOrder = temp;
        }
        else if (direction == 1 && index < list.Count - 1)
        {
            var other = list[index + 1];
            int temp = selectedAccount.SortOrder;
            selectedAccount.SortOrder = other.SortOrder;
            other.SortOrder = temp;
        }
        await Firebase.Save(myData);
    }

    // 🔥 Edit Name Logic (No Prompt)
    void PrepareEditName()
    {
        if (selectedAccount == null) return;
        editNameValue = selectedAccount.Name ?? "";
        isRenameModalVisible = true;
    }
    async Task SaveAccountName()
    {
        if (selectedAccount != null && !string.IsNullOrWhiteSpace(editNameValue))
        {
            selectedAccount.Name = editNameValue;
            await Firebase.Save(myData);
            isRenameModalVisible = false;
        }
    }

    // 🔥 Edit Balance Logic (No Prompt)
    void PrepareEditBalance()
    {
        if (selectedAccount == null) return;
        editBalanceValue = selectedAccount.Balance;
        isBalanceModalVisible = true;
    }
    async Task SaveAccountBalance()
    {
        if (selectedAccount != null)
        {
            selectedAccount.Balance = editBalanceValue;
            await Firebase.Save(myData);
            isBalanceModalVisible = false;
        }
    }

    // 🔥 Delete Account Logic (No Confirm)
    async Task ExecuteDeleteAccount()
    {
        if (selectedAccount != null)
        {
            myData.Accounts.Remove(selectedAccount);
            await Firebase.Save(myData);
            isDeleteAccConfirmVisible = false;
            isAccOptionsVisible = false;
        }
    }

    async Task AddCategory() { if (!string.IsNullOrEmpty(newCatName)) { if (isIncome) myData.IncomeCategories.Add(newCatName); else myData.ExpenseCategories.Add(newCatName); await Firebase.Save(myData); newCatName = ""; } }
    async Task DeleteCategory(string c) { if (isIncome) myData.IncomeCategories.Remove(c); else myData.ExpenseCategories.Remove(c); await Firebase.Save(myData); }

    void ShowTransactionModal(bool inc)
    {
        isIncome = inc; transAmount = 0; transDesc = ""; transDate = DateTime.Now; isTransModalVisible = true;
        var defaultCat = isIncome ? myData.IncomeCategories.FirstOrDefault() : myData.ExpenseCategories.FirstOrDefault();
        selectedCategory = defaultCat ?? L.T("Other");
    }

    async Task SaveTransaction()
    {
        var acc = myData.Accounts.FirstOrDefault(x => x.Id == selectedAccountId);
        if (acc == null) return;
        if (isIncome) acc.Balance += transAmount; else acc.Balance -= transAmount;
        myData.History.Add(new Transaction
        {
            Kind = isIncome ? "Income" : "Expense",
            Desc = string.IsNullOrEmpty(transDesc) ? selectedCategory : transDesc,
            Category = selectedCategory,
            Amount = transAmount,
            AmountDisplay = isIncome ? $"+{transAmount:N2}" : $"-{transAmount:N2}",
            ColorHex = isIncome ? "#2ecc71" : "#e74c3c",
            PrimaryAccountId = acc.Id,
            PrimaryAccountName = acc.Name,
            Date = transDate
        });
        await Firebase.Save(myData); isTransModalVisible = false;
    }

    void ConfirmDelete(Transaction t)
    {
        selectedTrans = t;
        isIncomeTrans = (t.AmountDisplay ?? "").StartsWith("+");
        refundAccountId = myData.Accounts.FirstOrDefault()?.Id ?? "";
        isDeleteModalVisible = true;
    }

    async Task ExecuteDelete()
    {
        if (!string.IsNullOrEmpty(refundAccountId))
        {
            if (refundAccountId.StartsWith("cc:"))
            {
                var ccId = refundAccountId.Replace("cc:", "");
                var cc = myData.CreditCards.FirstOrDefault(x => x.Id == ccId);
                if (cc != null)
                {
                    if (isIncomeTrans) cc.OutstandingBalance += selectedTrans.Amount;
                    else cc.OutstandingBalance -= selectedTrans.Amount;

                    if (cc.OutstandingBalance < 0) cc.OutstandingBalance = 0;
                }
            }
            else
            {
                var acc = myData.Accounts.FirstOrDefault(x => x.Id == refundAccountId);
                if (acc != null)
                {
                    if (isIncomeTrans) acc.Balance -= selectedTrans.Amount;
                    else acc.Balance += selectedTrans.Amount;
                }
            }
        }
        myData.History.Remove(selectedTrans);
        await Firebase.Save(myData);
        isDeleteModalVisible = false;
    }

    void ShowTransferModal()
    {
        if (myData.Accounts.Count < 2) return;
        transferFromId = myData.Accounts[0].Id; transferToId = myData.Accounts[1].Id;
        transferAmount = 0; transDesc = ""; transDate = DateTime.Now;
        isTransferModalVisible = true;
    }

    async Task SaveTransfer()
    {
        var f = myData.Accounts.FirstOrDefault(x => x.Id == transferFromId);
        var t = myData.Accounts.FirstOrDefault(x => x.Id == transferToId);
        if (f != null && t != null && f.Balance >= transferAmount)
        {
            f.Balance -= transferAmount; t.Balance += transferAmount;
            var desc = string.IsNullOrEmpty(transDesc) ? $"Trf {f.Name}->{t.Name}" : transDesc;
            myData.History.Add(new Transaction
            {
                Kind = "Transfer",
                Desc = desc,
                Category = "Transfer",
                Amount = transferAmount,
                AmountDisplay = $"{transferAmount:N2}",
                ColorHex = "#3498db",
                PrimaryAccountId = f.Id,
                PrimaryAccountName = f.Name,
                TargetAccountId = t.Id,
                TargetAccountName = t.Name,
                Date = transDate
            });
            await Firebase.Save(myData); isTransferModalVisible = false;
        }
    }
}