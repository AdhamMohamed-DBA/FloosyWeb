            <input type="number" @bind="transferAmount" class="input-dark" placeholder="@L.T("Amount")" />
            <input @bind="transDesc" class="input-dark" placeholder="@L.T("DescriptionOptional")" />
            <div style="display:flex; gap:10px;">
                <button class="btn-primary" @onclick="SaveTransfer" style="flex:1;">@L.T("Confirm")</button>
                <button class="btn-trans" @onclick="() => isTransferModalVisible = false" style="flex:1;">@L.T("Cancel")</button>
            </div>
        </div>
    </div>
}

